# Copy to .env: cp .env.example .env
# Local MySQL via Docker Compose (docker compose up -d)
DATABASE_URL="mysql://hrms:hrms_dev@localhost:3306/hrms"

# App
NODE_ENV="development"
API_PORT=3001
WEB_PORT=3000
API_URL="http://localhost:3001"
WEB_URL="http://localhost:3000"

# JWT (generate real secrets for non-dev)
JWT_ACCESS_SECRET="dev-access-secret-min-32-characters-long"
JWT_REFRESH_SECRET="dev-refresh-secret-min-32-characters-long"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"

# CORS
CORS_ORIGINS="http://localhost:3000,http://localhost:3001"

# File uploads (local folder — create on server)
UPLOAD_DIR="./uploads"
MAX_UPLOAD_MB=5

# Email — use "console" in dev (logs only) or SMTP
EMAIL_PROVIDER="console"
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM_EMAIL="noreply@localhost"
SMTP_FROM_NAME="GeneralHR"

# Payroll PHP integration (stub in dev)
PAYROLL_ADAPTER="stub"
PAYROLL_PHP_BASE_URL=""
PAYROLL_API_KEY=""

LOG_LEVEL="debug"
