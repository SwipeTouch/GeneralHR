// GeneralHR — minimal scope schema
// Docs: ../../docs/design/02-DATABASE-DESIGN.md

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Tenant & auth
// ---------------------------------------------------------------------------

enum TenantStatus {
  active
  inactive
}

model Tenant {
  id        String       @id @default(uuid())
  name      String       @db.VarChar(255)
  subdomain String       @unique @db.VarChar(100)
  status    TenantStatus @default(active)
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  users              User[]
  candidates         Candidate[]
  candidateComments  CandidateComment[]
  candidateDocuments CandidateDocument[]
  employees          Employee[]
  salaryHeads        SalaryHead[]
  employeeSalaryLines EmployeeSalaryLine[]
  attendanceRecords  AttendanceRecord[]
  settings           TenantSettings?

  @@map("tenants")
}

enum UserRole {
  system_admin
  hr_admin
  candidate
}

model User {
  id           String   @id @default(uuid())
  tenantId     String   @map("tenant_id")
  email        String   @db.VarChar(255)
  passwordHash String   @map("password_hash") @db.VarChar(255)
  role         UserRole
  candidateId  String?  @map("candidate_id")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  candidate Candidate? @relation(fields: [candidateId], references: [id], onDelete: SetNull)

  commentsCreated       CandidateComment[]  @relation("CommentAuthor")
  documentsUnlocked     CandidateDocument[] @relation("DocumentUnlockedBy")
  candidatesCreated     Candidate[]         @relation("CandidateCreatedBy")

  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("users")
}

// ---------------------------------------------------------------------------
// Recruitment
// ---------------------------------------------------------------------------

enum CandidateStatus {
  NOT_STARTED
  SCREENED
  TECH_ROUND_1
  TECH_ROUND_2
  TECH_ROUND_3
  FINAL_ROUND
  OFFER_ROUND
  SELECTED
  OFFERED
  JOINING
  JOINED
  NOT_INTERESTED
  NOT_RESPONDING
}

model Candidate {
  id             String          @id @default(uuid())
  tenantId       String          @map("tenant_id")
  fullName       String          @map("full_name") @db.VarChar(255)
  email          String          @db.VarChar(255)
  phone          String?         @db.VarChar(20)
  status         CandidateStatus @default(NOT_STARTED)
  notes          String?         @db.Text
  portalEnabled  Boolean         @default(false) @map("portal_enabled")
  createdById    String?         @map("created_by")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  tenant    Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy User?  @relation("CandidateCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  comments  CandidateComment[]
  documents CandidateDocument[]
  portalUsers User[]

  @@index([tenantId, status])
  @@index([tenantId, email])
  @@map("candidates")
}

model CandidateComment {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  candidateId String   @map("candidate_id")
  content     String   @db.Text
  createdById String   @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")

  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  candidate Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  createdBy User      @relation("CommentAuthor", fields: [createdById], references: [id], onDelete: Restrict)

  @@index([candidateId, createdAt])
  @@map("candidate_comments")
}

enum DocumentUploadStatus {
  draft
  submitted
}

model CandidateDocument {
  id           String               @id @default(uuid())
  tenantId     String               @map("tenant_id")
  candidateId  String               @map("candidate_id")
  documentType String               @map("document_type") @db.VarChar(100)
  fileName     String               @map("file_name") @db.VarChar(255)
  filePath     String               @map("file_path") @db.VarChar(500)
  mimeType     String               @map("mime_type") @db.VarChar(100)
  fileSize     Int                  @map("file_size")
  status       DocumentUploadStatus @default(draft)
  isLocked     Boolean              @default(false) @map("is_locked")
  unlockedById String?              @map("unlocked_by")
  unlockedAt   DateTime?            @map("unlocked_at")
  submittedAt  DateTime?            @map("submitted_at")
  uploadedAt   DateTime             @default(now()) @map("uploaded_at")
  updatedAt    DateTime             @updatedAt @map("updated_at")

  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  candidate  Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  unlockedBy User?     @relation("DocumentUnlockedBy", fields: [unlockedById], references: [id], onDelete: SetNull)

  @@index([candidateId])
  @@map("candidate_documents")
}

// ---------------------------------------------------------------------------
// Staff & attendance
// ---------------------------------------------------------------------------

enum EmployeeStatus {
  active
  inactive
}

model Employee {
  id           String         @id @default(uuid())
  tenantId     String         @map("tenant_id")
  employeeCode String         @map("employee_code") @db.VarChar(50)
  fullName     String         @map("full_name") @db.VarChar(255)
  email        String?        @db.VarChar(255)
  phone        String?        @db.VarChar(20)
  department   String?        @db.VarChar(100)
  joiningDate  DateTime?      @map("joining_date") @db.Date
  status       EmployeeStatus @default(active)
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")

  tenant     Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  salaryLines EmployeeSalaryLine[]
  attendance AttendanceRecord[]

  @@unique([tenantId, employeeCode])
  @@index([tenantId])
  @@map("employees")
}

enum SalaryHeadType {
  earning
  deduction
}

model SalaryHead {
  id        String         @id @default(uuid())
  tenantId  String         @map("tenant_id")
  code      String         @db.VarChar(50)
  name      String         @db.VarChar(100)
  type      SalaryHeadType
  isTaxable Boolean        @default(false) @map("is_taxable")
  sortOrder Int            @default(0) @map("sort_order")
  isActive  Boolean        @default(true) @map("is_active")
  createdAt DateTime       @default(now()) @map("created_at")
  updatedAt DateTime       @updatedAt @map("updated_at")

  tenant Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  lines  EmployeeSalaryLine[]

  @@unique([tenantId, code])
  @@map("salary_heads")
}

model EmployeeSalaryLine {
  id            String    @id @default(uuid())
  tenantId      String    @map("tenant_id")
  employeeId    String    @map("employee_id")
  salaryHeadId  String    @map("salary_head_id")
  amount        Decimal   @db.Decimal(12, 2)
  effectiveFrom DateTime? @map("effective_from") @db.Date
  updatedAt     DateTime  @updatedAt @map("updated_at")

  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee   Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  salaryHead SalaryHead @relation(fields: [salaryHeadId], references: [id], onDelete: Restrict)

  @@unique([employeeId, salaryHeadId])
  @@map("employee_salary_lines")
}

enum AttendanceSource {
  biometric
  manual
  file_import
}

model AttendanceRecord {
  id          String           @id @default(uuid())
  tenantId    String           @map("tenant_id")
  employeeId  String           @map("employee_id")
  date        DateTime         @db.Date
  checkIn     DateTime?        @map("check_in") @db.Time(0)
  checkOut    DateTime?        @map("check_out") @db.Time(0)
  source      AttendanceSource
  externalRef String?          @map("external_ref") @db.VarChar(100)
  createdAt   DateTime         @default(now()) @map("created_at")

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([tenantId, employeeId, date])
  @@map("attendance_records")
}

// ---------------------------------------------------------------------------
// Settings
// ---------------------------------------------------------------------------

model TenantSettings {
  tenantId               String  @id @map("tenant_id")
  payrollPhpBaseUrl      String? @map("payroll_php_base_url") @db.VarChar(500)
  payrollApiKey          String? @map("payroll_api_key") @db.VarChar(500)
  payrollSyncEnabled     Boolean @default(false) @map("payroll_sync_enabled")
  attendanceImportFormat Json?   @map("attendance_import_format")
  allowedDocumentTypes   Json?   @map("allowed_document_types")
  maxUploadMb            Int     @default(5) @map("max_upload_mb")
  hrNotificationEmails   Json?   @map("hr_notification_emails")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tenant_settings")
}
